<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="26dp"
    android:background="#1A1524">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        <View
            android:layout_width="6dp"
            android:layout_height="45dp"
            android:background="#BB86FC"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp">
            <TextView
                android:id="@+id/tvSettingsUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SecureSphere User"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvSettingsUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="loading telemetry parameters..."
                android:textColor="#A599B5"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#251E33"
        android:padding="12dp"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡️ System Shield Status: ENFORCED"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦 Local Database Vault: Encrypted (AES-256)"
            android:textColor="#A599B5"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E253D"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnYourInformation"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Your Information"
        android:textColor="#FFFFFF"
        android:gravity="start|center_vertical"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btnDialogChangePassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Change Password"
        android:textColor="#FFFFFF"
        android:gravity="start|center_vertical"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btnAboutApp"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="About SecureSphere"
        android:textColor="#FFFFFF"
        android:gravity="start|center_vertical"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btnSendFeedback"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Transmit Feedback"
        android:textColor="#FFFFFF"
        android:gravity="start|center_vertical"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="24dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙 Dark Engine Core"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_centerVertical="true"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchTheme"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            app:thumbTint="#BB86FC"
            app:trackTint="#46385C"/>
    </RelativeLayout>



    <Button
        android:id="@+id/btnDialogDisconnect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Log Out"
        android:backgroundTint="#BB86FC"
        android:textColor="#121212"
        android:textStyle="bold"
        android:textAllCaps="false"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_marginTop="12dp"/>
</LinearLayout>