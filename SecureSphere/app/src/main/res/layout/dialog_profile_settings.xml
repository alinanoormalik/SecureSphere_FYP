<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="26dp"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        <View
            android:layout_width="6dp"
            android:layout_height="45dp"
            android:background="?attr/colorPrimary"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp">
            <TextView
                android:id="@+id/tvSettingsUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SecureSphere User"
                android:textColor="?attr/colorOnSurface"
                android:textSize="20sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvSettingsUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙 Dark Engine Core"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:layout_centerVertical="true"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchTheme"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            app:thumbTint="?attr/colorPrimary"
            app:trackTint="?attr/colorOutline"/>
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnYourInformation"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Your Information"
        android:textColor="?attr/colorOnSurface"
        android:gravity="start|center_vertical"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btnDialogChangePassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Change Password"
        android:textColor="?attr/colorOnSurface"
        android:gravity="start|center_vertical"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btnAboutApp"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="About SecureSphere"
        android:textColor="?attr/colorOnSurface"
        android:gravity="start|center_vertical"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btnSendFeedback"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Transmit Feedback"
        android:textColor="?attr/colorOnSurface"
        android:gravity="start|center_vertical"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnDialogDisconnect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Log Out"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOnPrimary"
        android:textStyle="bold"
        android:textAllCaps="false"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_marginTop="12dp"/>
</LinearLayout>