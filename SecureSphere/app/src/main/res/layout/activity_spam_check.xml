<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="?attr/colorSurface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spam URL Detector"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:boxStrokeColor="?attr/colorPrimary"
        app:hintTextColor="?attr/colorPrimary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Paste URL to analyze..."
            android:inputType="textUri"
            android:textColor="?attr/colorOnSurface"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="SCAN LINK"
        android:layout_marginTop="16dp"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOnPrimary"
        android:textStyle="bold"
        app:cornerRadius="8dp"/>

    <!-- RESULT CARD: Matches your theme and supports Dark Mode -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/resultCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurface"
        app:strokeColor="?attr/colorPrimary"
        app:strokeWidth="1dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvMainStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCAN RESULT"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="..."
                android:layout_marginTop="4dp"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.7"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOnSurface"
                android:alpha="0.1"
                android:layout_marginVertical="12dp"/>

            <TextView
                android:id="@+id/tvConfidenceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Confidence"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/confidenceBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:trackThickness="8dp"
                app:trackCornerRadius="4dp"
                app:indicatorColor="?attr/colorPrimary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>