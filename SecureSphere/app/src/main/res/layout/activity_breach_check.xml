<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Social Media Breach &amp; Audit Engine"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etBreachEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter email address to evaluate"
            android:textColorHint="#757575"
            android:textColor="#FFFFFF"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Active Posture Self-Assessment Options:"
            android:textColor="#B0BEC5"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/cb2FA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Two-Factor Authentication (2FA) is Disabled"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/cbReuse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I reuse passwords across multiple social profiles"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/cbLegacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Outdated / Legacy applications have profile access"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnCheckBreach"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Run Security Audit"
            android:backgroundTint="#1E88E5"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:id="@+id/resultContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvRiskBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOW RISK"
                android:padding="8dp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvBreachResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Identified Exposure Sources:"
                android:textColor="#B0BEC5"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:id="@+id/dynamicBreachList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>