<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2D243A" /> <corners android:radius="18dp" />
            <stroke android:width="2dp" android:color="#BB86FC" /> </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#2D243A" />
            <corners android:radius="18dp" />
            <stroke android:width="2dp" android:color="#BB86FC" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1524" /> <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#2E253D" />
        </shape>
    </item>
</selector>